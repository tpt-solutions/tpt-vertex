{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TPT Vertex",
  "version": "0.1.0",
  "identifier": "dev.tpt-vertex.desktop",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "TPT Vertex",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Parametric 3D CAD — the Figma for Hardware.",
    "longDescription": "TPT Vertex desktop client: a modern, collaborative, parametric 3D CAD tool with an embedded Rust geometry kernel for offline-first local editing.",
    "licenseFile": "../../LICENSE-APACHE"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://releases.tpt-vertex.dev/desktop/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}
